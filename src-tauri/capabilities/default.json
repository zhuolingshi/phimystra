{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-read-file",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://cdn.jsdelivr.net/*" },
        { "url": "https://gh-proxy.com/*" }
      ]
    },
    "opener:default"
  ]
}
